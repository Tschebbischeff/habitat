# This file contains environment variables for the build-context.
# It is also passed into every single docker container.
# Use files in .env.d to overwrite environment variables or pass variables into individual docker containers only.
# Deployment variables:
MODULE_DEPLOY_PATH="${MODULE_DEPLOY_PATH:-$PWD/habitat-modules}"
MODULE_LIST="${MODULE_LIST:-path,scent,vista}"
MODULE_ENV_FILE="${MODULE_ENV_FILE:-./_.env}"
RUN_AS_USER="${RUN_AS_USER:-}"
RUN_AS_GROUP="${RUN_AS_GROUP:-}"
UPDATE_MODULES="yes"